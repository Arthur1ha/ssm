# OpenAI-compatible API — 换模型只需改这三行
OPENAI_API_KEY="your-api-key-here"
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# 按顺序尝试，前一个 429/限额时自动切下一个
MODEL_LIST=doubao-seed-2-0-lite-260215,doubao-seed-2-0-mini-260215,doubao-seed-2-0-pro-260215,doubao-seed-1-8-251228,doubao-seed-1-6-lite-251015,doubao-seed-code-preview-251028,deepseek-v3-2-251201


# MQTT broker（与 ESP32 config.py 中的 MQTT_BROKER_IP 保持一致）
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883

# 编排器 MQTT 身份
ORCHESTRATOR_ID=cloud_orchestrator
