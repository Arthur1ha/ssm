# ── SJTU DeepSeek API（编排器、ESP32 智能体、Go2 智能体统一使用）──
OPENAI_API_KEY="sk-aXMf99O2v2myNq_co9Qrfg"
OPENAI_BASE_URL="https://models.sjtu.edu.cn/api/v1"
# 按顺序尝试，前一个 429/限额时自动切下一个
MODEL_LIST=deepseek-chat

# Go2 智能体模型（文本/视觉分开，视觉必须用 qwen 别名，全名调用报错）
GO2_TEXT_MODEL=deepseek-chat
GO2_VISION_MODEL=qwen


# MQTT broker（与 ESP32 config.py 中的 MQTT_BROKER_IP 保持一致）
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883

# 编排器 MQTT 身份
ORCHESTRATOR_ID=cloud_orchestrator

