# SSM Mosquitto Broker Configuration
# 此文件是模板，由 make broker 通过 envsubst 生成最终配置
# 不要直接修改 mosquitto.conf，修改此模板文件

# Authentication
password_file ${SSM_DIR}/infra/broker/passwd
allow_anonymous false

# TCP listener for ESP32 (port 1883)
listener 1883

# WebSocket listener for PWA (port 9001)
listener 9001
protocol websockets

# Persistence (retain messages survive restarts)
persistence true
persistence_location ${SSM_DIR}/logs/broker/
retained_persistence true

# Logging
log_dest stdout
log_dest file ${SSM_DIR}/logs/mosquitto.log
log_type error
log_type warning
log_type notice
log_type information
# 规范日志时间戳：年月日 + 时间（mosquitto 默认输出 Unix 秒，不可读）
log_timestamp_format %Y-%m-%d %H:%M:%S

# Connection settings
max_keepalive 120
